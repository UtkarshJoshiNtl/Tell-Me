# Supabase: Project Settings → API (use either NEXT_PUBLIC_* or SUPABASE_* names)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional aliases (same values; useful if you copied CLI-style names):
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Auth → URL configuration: add redirect URL
#   http://localhost:3000/auth/callback
# (and your production /auth/callback)
