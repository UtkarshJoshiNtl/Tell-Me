# Supabase: Project Settings → API (use either NEXT_PUBLIC_* or SUPABASE_* names)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Expenses UI: ISO 4217 code (default USD)
NEXT_PUBLIC_DEFAULT_CURRENCY=USD

# Set to 1 to register the service worker in development (default: production only)
# NEXT_PUBLIC_ENABLE_SW=1
# Optional aliases (same values; useful if you copied CLI-style names):
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Auth → URL configuration (Authentication → URL configuration in Supabase):
#   http://localhost:3000/auth/callback
#   http://localhost:3000/auth/update-password
# (add the same paths on your production origin)
